{
  "name": "bloomerp",
  "version": "3.8.0",
  "description": "Bloomerp Django static assets with TypeScript and Vite bundling",
  "type": "module",
  "scripts": {
    "postinstall": "node ./scripts/copy-fontawesome.mjs",
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\"",
    "dev:css": "cross-env NODE_ENV=development tailwindcss --postcss -i ./src/styles.css -o ../static/css/dist/styles.css -w",
    "dev:js": "vite",
    "build:fontawesome": "node ./scripts/copy-fontawesome.mjs",
    "build": "npm run build:fontawesome && npm run build:clean && npm run build:tailwind && npm run build:js",
    "build:clean": "rimraf ../static/css/dist ../static/bloomerp/js/dist",
    "build:tailwind": "cross-env NODE_ENV=production tailwindcss --postcss -i ./src/styles.css -o ../static/css/dist/styles.css --minify",
    "build:js": "tsc && vite build",
    "preview": "vite preview",
    "tailwindcss": "node ./node_modules/tailwindcss/lib/cli.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/drawflow": "^0.0.12",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.1",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "postcss-url": "^10.1.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@lexical/html": "^0.18.0",
    "@lexical/link": "^0.18.0",
    "@lexical/list": "^0.18.0",
    "@lexical/rich-text": "^0.18.0",
    "@lexical/selection": "^0.18.0",
    "@tailwindcss/postcss": "^4.1.18",
    "ace-builds": "^1.32.9",
    "alpinejs": "^3.15.3",
    "drawflow": "^0.0.60",
    "grapesjs": "^0.22.14",
    "grapesjs-preset-webpage": "^1.0.3",
    "htmx.org": "^2.0.3",
    "lexical": "^0.18.0"
  }
}
